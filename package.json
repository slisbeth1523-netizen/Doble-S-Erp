{
  "name": "doble-s-erp",
  "version": "0.1.0",
  "private": true,
  "description": "Doble S ERP - monorepo SaaS modular multiempresa.",
  "workspaces": [
    "packages/shared",
    "packages/config",
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "db:migrate": "node scripts/run-sqlserver-migrations.mjs",
    "db:seed": "node scripts/seed-local-data.mjs",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "build": "npm --workspaces run build",
    "typecheck": "npm --workspaces run typecheck"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
